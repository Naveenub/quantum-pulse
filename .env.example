# QUANTUM-PULSE environment configuration
# Copy to .env and fill in your values:  cp .env.example .env

# ── Security (REQUIRED — change before deploying) ─────────────────────────
QUANTUM_PASSPHRASE=change-me-in-production-minimum-16-chars

# ── API keys (JSON array of valid keys) ──────────────────────────────────
QUANTUM_API_KEYS=["your-api-key-here"]

# ── Environment ───────────────────────────────────────────────────────────
QUANTUM_ENVIRONMENT=development   # development | production

# ── MongoDB ───────────────────────────────────────────────────────────────
QUANTUM_MONGO_URI=mongodb://localhost:27017
QUANTUM_MONGO_DB=quantum_pulse

# ── API server ────────────────────────────────────────────────────────────
QUANTUM_HOST=0.0.0.0
QUANTUM_PORT=8747

# ── Logging ───────────────────────────────────────────────────────────────
QUANTUM_LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
QUANTUM_LOG_DIR=logs
QUANTUM_LOG_FORMAT=text           # text | json
QUANTUM_LOG_ROTATION=100 MB
QUANTUM_LOG_RETENTION=30 days

# ── Rate limiting ─────────────────────────────────────────────────────────
QUANTUM_RATE_LIMIT_ENABLED=true
QUANTUM_RATE_LIMIT=100/minute

# ── TTL cleanup (optional) ────────────────────────────────────────────────
# QUANTUM_PULSE_TTL_DAYS=90       # delete pulses older than N days (disabled by default)
